<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Uncomment once Apple grants the multicast entitlement request
	     (developer.apple.com/contact/request/networking-multicast).
	     Enabling it before the grant makes code signing fail, because the
	     provisioning profile won't include the entitlement yet.
	<key>com.apple.developer.networking.multicast</key>
	<true/>
	-->
</dict>
</plist>
